generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  EDUCATOR
  PARENT
  STUDENT
}

enum EducatorStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum LessonProgramStatus {
  ACTIVE
  INACTIVE
}

enum EducatorLessonStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum Subject {
  TURKCE
  MATEMATIK
  FEN_BILIMLERI
  SOSYAL_BILGILER
  INGILIZCE
  INKILAP_TARIHI
  ILK_OKUMA_YAZMA
  HAYAT_BILGISI
  OGRENCI_KOCLUGU
  DIGER
}

enum GradeLevel {
  ILKOKUL_1
  ILKOKUL_2
  ILKOKUL_3
  ILKOKUL_4
  ORTAOKUL_5
  ORTAOKUL_6
  ORTAOKUL_7
  ORTAOKUL_8
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(PARENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  educator  Educator?
  parent    Parent?
  notifications Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Educator {
  id              String         @id @default(cuid())
  userId          String         @unique
  bio             String?        @db.Text
  subjects        Subject[]
  gradeLevels     GradeLevel[]
  hourlyRate      Decimal        @db.Decimal(10, 2)
  status          EducatorStatus @default(PENDING)
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionNote   String?
  phone           String?
  photoUrl        String?
  diplomaUrl      String?
  idCardUrl       String?
  titleName       String?
  experience      Int?
  skills          String[]
  certificates    String[]
  linkedinUrl     String?
  isProfilePublic Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  availabilitySlots AvailabilitySlot[]
  bookings          Booking[]
  educatorLessons   EducatorLesson[]
  reviews           Review[]
  resources         EducatorResource[]
  lessonReports     LessonReport[]
}

model Parent {
  id        String   @id @default(cuid())
  userId    String   @unique
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  students Student[]
}

model Student {
  id         String     @id @default(cuid())
  parentId   String
  name       String
  gradeLevel GradeLevel
  birthDate  DateTime?
  notes      String?    @db.Text
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  parent   Parent    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  bookings Booking[]
  reviews  Review[]
}

model AvailabilitySlot {
  id         String   @id @default(cuid())
  educatorId String
  date       DateTime @db.Date
  startTime  String
  endTime    String
  isBooked   Boolean  @default(false)
  createdAt  DateTime @default(now())

  educator Educator  @relation(fields: [educatorId], references: [id], onDelete: Cascade)
  booking  Booking?

  @@unique([educatorId, date, startTime])
}

model Booking {
  id               String        @id @default(cuid())
  studentId        String
  educatorId       String
  slotId           String        @unique
  educatorLessonId String?
  subject          Subject
  gradeLevel       GradeLevel?
  topicId          String?
  notes            String?       @db.Text
  status           BookingStatus @default(PENDING)
  totalPrice       Decimal       @db.Decimal(10, 2)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  meetingUrl     String?

  student        Student          @relation(fields: [studentId], references: [id])
  educator       Educator         @relation(fields: [educatorId], references: [id])
  slot           AvailabilitySlot @relation(fields: [slotId], references: [id])
  topic          CurriculumTopic? @relation(fields: [topicId], references: [id], onDelete: SetNull)
  educatorLesson EducatorLesson?  @relation(fields: [educatorLessonId], references: [id])
  payment        Payment?
  assessment     LevelAssessment?
  lessonReport   LessonReport?
}

model Payment {
  id              String        @id @default(cuid())
  bookingId       String        @unique
  iyzicoPaymentId String?
  iyzicoToken     String?
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("TRY")
  status          PaymentStatus @default(PENDING)
  installment     Int           @default(1)
  receiptUrl      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String   @db.Text
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LessonProgram {
  id          String              @id @default(cuid())
  name        String
  description String?             @db.Text
  subject     Subject
  gradeLevel  GradeLevel
  durationMin Int                 @default(45)
  maxStudents Int                 @default(1)
  status      LessonProgramStatus @default(ACTIVE)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  educatorLessons EducatorLesson[]
}

model EducatorLesson {
  id              String               @id @default(cuid())
  educatorId      String
  lessonProgramId String
  price           Decimal              @db.Decimal(10, 2)
  status          EducatorLessonStatus @default(PENDING_APPROVAL)
  rejectionNote   String?
  approvedAt      DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  educator      Educator      @relation(fields: [educatorId], references: [id], onDelete: Cascade)
  lessonProgram LessonProgram @relation(fields: [lessonProgramId], references: [id])
  bookings      Booking[]

  @@unique([educatorId, lessonProgramId])
}

model Review {
  id             String   @id @default(cuid())
  educatorId     String
  studentId      String
  rating         Int
  comment        String?  @db.Text
  isPublic       Boolean  @default(true)
  createdAt      DateTime @default(now())

  educator Educator @relation(fields: [educatorId], references: [id], onDelete: Cascade)
  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([educatorId, studentId])
}

enum AssessmentStatus {
  PENDING
  COMPLETED
}

model EducatorResource {
  id          String   @id @default(cuid())
  educatorId  String
  title       String
  description String?  @db.Text
  fileUrl     String
  subject     Subject?
  isFree      Boolean  @default(true)
  createdAt   DateTime @default(now())

  educator Educator @relation(fields: [educatorId], references: [id], onDelete: Cascade)
}

model CurriculumTopic {
  id           String   @id @default(cuid())
  subject      String
  gradeLevel   Int
  name         String
  description  String?
  unit         String?
  learningObjects String[] @default([])
  createdAt    DateTime @default(now())

  assessments  LevelAssessment[]
  bookings     Booking[]

  @@unique([subject, gradeLevel, name])
  @@index([subject, gradeLevel])
  @@map("curriculum_topics")
}

model LevelAssessment {
  id          String           @id @default(cuid())
  bookingId   String           @unique
  studentId   String
  subject     Subject
  gradeLevel  GradeLevel
  status      AssessmentStatus @default(PENDING)
  sentAt      DateTime         @default(now())
  completedAt DateTime?
  topicId     String?

  booking   Booking              @relation(fields: [bookingId], references: [id])
  topic     CurriculumTopic?     @relation(fields: [topicId], references: [id], onDelete: SetNull)
  responses AssessmentResponse[]

  @@index([topicId])
}

model AssessmentResponse {
  id             String @id @default(cuid())
  assessmentId   String
  questionIndex  Int
  selectedAnswer Int

  assessment LevelAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model LessonReport {
  id            String   @id @default(cuid())
  bookingId     String   @unique
  educatorId    String
  topicsCovered String   @db.Text
  nextSteps     String   @db.Text
  homework      String?  @db.Text
  notes         String?  @db.Text
  createdAt     DateTime @default(now())

  booking  Booking  @relation(fields: [bookingId], references: [id])
  educator Educator @relation(fields: [educatorId], references: [id])
}

model PricingPlan {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  duration    Int      // dakika cinsinden ders süresi
  features    String[]
  isPopular   Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
